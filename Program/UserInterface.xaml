<Window x:Class="Matrix.UserInterface"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Обернення матриці — Курсова робота"
        Width="1100" Height="750"
        MinWidth="900" MinHeight="600"
        WindowStartupLocation="CenterScreen"
        Background="#1E1E2E">

    <Window.Resources>
        <!-- Стиль кнопок -->
        <Style x:Key="PrimaryButton" TargetType="Button">
            <Setter Property="Background" Value="#6C63FF"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Padding" Value="16,8"/>
            <Setter Property="Margin" Value="0,4"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="border" Background="{TemplateBinding Background}"
                                CornerRadius="6" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="border" Property="Background" Value="#7B73FF"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="border" Property="Background" Value="#5A52E0"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="border" Property="Background" Value="#3E3E5E"/>
                                <Setter Property="Foreground" Value="#888"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="SecondaryButton" TargetType="Button" BasedOn="{StaticResource PrimaryButton}">
            <Setter Property="Background" Value="#2D2D44"/>
        </Style>

        <Style x:Key="SuccessButton" TargetType="Button" BasedOn="{StaticResource PrimaryButton}">
            <Setter Property="Background" Value="#2ECC71"/>
        </Style>

        <!-- Стиль DataGrid -->
        <Style x:Key="MatrixGrid" TargetType="DataGrid">
            <Setter Property="Background" Value="#2D2D44"/>
            <Setter Property="Foreground" Value="#E0E0E0"/>
            <Setter Property="BorderBrush" Value="#3E3E5E"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="RowBackground" Value="#2D2D44"/>
            <Setter Property="AlternatingRowBackground" Value="#333352"/>
            <Setter Property="GridLinesVisibility" Value="All"/>
            <Setter Property="HorizontalGridLinesBrush" Value="#3E3E5E"/>
            <Setter Property="VerticalGridLinesBrush" Value="#3E3E5E"/>
            <Setter Property="HeadersVisibility" Value="None"/>
            <Setter Property="AutoGenerateColumns" Value="True"/>
            <Setter Property="CanUserAddRows" Value="False"/>
            <Setter Property="CanUserDeleteRows" Value="False"/>
            <Setter Property="CanUserResizeRows" Value="False"/>
            <Setter Property="IsReadOnly" Value="True"/>
            <Setter Property="FontFamily" Value="Consolas"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="SelectionMode" Value="Single"/>
        </Style>

        <!-- Стиль TextBox -->
        <Style x:Key="InputBox" TargetType="TextBox">
            <Setter Property="Background" Value="#2D2D44"/>
            <Setter Property="Foreground" Value="#E0E0E0"/>
            <Setter Property="BorderBrush" Value="#3E3E5E"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="8,6"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="CaretBrush" Value="#E0E0E0"/>
        </Style>

        <!-- Стиль GroupBox -->
        <Style TargetType="GroupBox">
            <Setter Property="Foreground" Value="#B0B0D0"/>
            <Setter Property="BorderBrush" Value="#3E3E5E"/>
            <Setter Property="Margin" Value="0,0,0,8"/>
        </Style>

        <!-- Стиль RadioButton -->
        <Style TargetType="RadioButton">
            <Setter Property="Foreground" Value="#C0C0E0"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Margin" Value="0,3"/>
        </Style>

        <!-- Стиль Label -->
        <Style TargetType="Label">
            <Setter Property="Foreground" Value="#B0B0D0"/>
            <Setter Property="FontSize" Value="13"/>
        </Style>
    </Window.Resources>

    <Grid Margin="12">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="220"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- ═══ ЛІВА ПАНЕЛЬ: Параметри ═══ -->
        <Border Grid.Column="0" Background="#252540" CornerRadius="10" Padding="14" Margin="0,0,10,0">
            <StackPanel>
                <TextBlock Text="⚙ Параметри" FontSize="16" FontWeight="Bold"
                           Foreground="#C0C0FF" Margin="0,0,0,12"/>

                <!-- Розмір матриці -->
                <Label Content="Розмірність (N×N):" Padding="0" Margin="0,0,0,4"/>
                <TextBox x:Name="txtDimension" Style="{StaticResource InputBox}" Text="3"/>

                <Separator Background="#3E3E5E" Margin="0,12"/>

                <!-- Введення матриці -->
                <TextBlock Text="Введення матриці" FontSize="13" FontWeight="SemiBold"
                           Foreground="#9090B0" Margin="0,0,0,6"/>
                <Button x:Name="btnManualInput" Content="✏ Ввести вручну"
                        Style="{StaticResource SecondaryButton}" Click="BtnManualInput_Click"/>
                <Button x:Name="btnRandom" Content="🎲 Випадкова матриця"
                        Style="{StaticResource SecondaryButton}" Click="BtnRandom_Click"/>

                <Separator Background="#3E3E5E" Margin="0,12"/>

                <!-- Метод обернення -->
                <TextBlock Text="Метод обернення" FontSize="13" FontWeight="SemiBold"
                           Foreground="#9090B0" Margin="0,0,0,6"/>
                <RadioButton x:Name="rbGauss" Content="Метод Гаусса" IsChecked="True"/>
                <RadioButton x:Name="rbBlock" Content="Блочний метод"/>
                <RadioButton x:Name="rbBoth" Content="Обидва методи"/>

                <Separator Background="#3E3E5E" Margin="0,12"/>

                <!-- Дії -->
                <Button x:Name="btnInvert" Content="▶ Обернути матрицю"
                        Style="{StaticResource PrimaryButton}" Click="BtnInvert_Click"
                        IsEnabled="False"/>
                <Button x:Name="btnVerify" Content="✓ Перевірити A·A⁻¹=E"
                        Style="{StaticResource SuccessButton}" Click="BtnVerify_Click"
                        IsEnabled="False"/>
                <Button x:Name="btnSave" Content="💾 Зберегти у файл"
                        Style="{StaticResource SecondaryButton}" Click="BtnSave_Click"
                        IsEnabled="False"/>

                <Separator Background="#3E3E5E" Margin="0,12"/>

                <!-- Час виконання -->
                <TextBlock Text="Продуктивність" FontSize="13" FontWeight="SemiBold"
                           Foreground="#9090B0" Margin="0,0,0,4"/>
                <TextBlock x:Name="txtPerformance" Text="—" Foreground="#7EE07E"
                           FontFamily="Consolas" FontSize="12" TextWrapping="Wrap"/>
            </StackPanel>
        </Border>

        <!-- ═══ ПРАВА ПАНЕЛЬ: Матриці ═══ -->
        <ScrollViewer Grid.Column="1" VerticalScrollBarVisibility="Auto">
            <StackPanel>
                <!-- Вхідна матриця -->
                <Border Background="#252540" CornerRadius="10" Padding="14" Margin="0,0,0,10">
                    <StackPanel>
                        <TextBlock Text="📊 Вхідна матриця" FontSize="14" FontWeight="Bold"
                                   Foreground="#C0C0FF" Margin="0,0,0,8"/>
                        <DataGrid x:Name="gridInput" Style="{StaticResource MatrixGrid}"
                                  MaxHeight="200" CellEditEnding="GridInput_CellEditEnding"
                                  PreparingCellForEdit="GridInput_PreparingCellForEdit"/>
                    </StackPanel>
                </Border>

                <!-- Обернена матриця (Гаусс) -->
                <Border x:Name="panelGauss" Background="#252540" CornerRadius="10"
                        Padding="14" Margin="0,0,0,10" Visibility="Collapsed">
                    <StackPanel>
                        <TextBlock Text="🔄 Обернена матриця (метод Гаусса)" FontSize="14"
                                   FontWeight="Bold" Foreground="#FFD166" Margin="0,0,0,4"/>
                        <TextBlock x:Name="txtGaussTime" Foreground="#7EE07E"
                                   FontFamily="Consolas" FontSize="12" Margin="0,0,0,8"/>
                        <DataGrid x:Name="gridGauss" Style="{StaticResource MatrixGrid}" MaxHeight="200"/>
                    </StackPanel>
                </Border>

                <!-- Обернена матриця (Блочний) -->
                <Border x:Name="panelBlock" Background="#252540" CornerRadius="10"
                        Padding="14" Margin="0,0,0,10" Visibility="Collapsed">
                    <StackPanel>
                        <TextBlock Text="🔄 Обернена матриця (блочний метод)" FontSize="14"
                                   FontWeight="Bold" Foreground="#FF6B6B" Margin="0,0,0,4"/>
                        <TextBlock x:Name="txtBlockTime" Foreground="#7EE07E"
                                   FontFamily="Consolas" FontSize="12" Margin="0,0,0,8"/>
                        <DataGrid x:Name="gridBlock" Style="{StaticResource MatrixGrid}" MaxHeight="200"/>
                    </StackPanel>
                </Border>

                <!-- Перевірка -->
                <Border x:Name="panelVerify" Background="#252540" CornerRadius="10"
                        Padding="14" Margin="0,0,0,10" Visibility="Collapsed">
                    <StackPanel>
                        <TextBlock Text="✅ Перевірка: A · A⁻¹ (одинична матриця)" FontSize="14"
                                   FontWeight="Bold" Foreground="#2ECC71" Margin="0,0,0,8"/>
                        <DataGrid x:Name="gridVerify" Style="{StaticResource MatrixGrid}" MaxHeight="200"/>
                    </StackPanel>
                </Border>

                <!-- Статус -->
                <Border Background="#252540" CornerRadius="10" Padding="14">
                    <TextBlock x:Name="txtStatus" Text="Готово до роботи."
                               Foreground="#B0B0D0" FontSize="13" TextWrapping="Wrap"/>
                </Border>
            </StackPanel>
        </ScrollViewer>
    </Grid>
</Window>
